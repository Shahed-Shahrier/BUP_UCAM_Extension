{
  "manifest_version": 3,
  "name": "BUP UCAM Extension",
  "version": "1.2.0",
  "version_name": "BUP UCAM Extension 1.2",
  "description": "Adds UCAM evaluation quick-select, exam planning, lab in-course totals, and attendance alerts.",
  "content_scripts": [
    {
      "matches": [
        "*://*.bup.edu.bd/*"
      ],
      "js": [
        "scripts/core.js",
        "scripts/evaluation-quick-select.js",
        "scripts/exam-planner.js",
        "scripts/attendance-percentage.js",
        "content.js"
      ],
      "css": ["styles.css"]
    }
  ]
}
